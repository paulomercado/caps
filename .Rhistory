# ── Info lists ───────────────────────────────────────────
bp_tax <- breakpoints(tax_ts ~ 1, h = h_value)
bp_bir <- breakpoints(bir_ts ~ 1, h = h_value)
bp_boc <- breakpoints(boc_ts ~ 1, h = h_value)
bp_exp <- breakpoints(exp_ts ~ 1, h = h_value)
growth_info <- list(
list(name = "Tax Revenues",  ts = tax_ts, bp = bp_tax, n = 6),
list(name = "BIR",           ts = bir_ts, bp = bp_bir, n = 1),
list(name = "BOC",           ts = boc_ts, bp = bp_boc, n = 9),
list(name = "Expenditures",  ts = exp_ts, bp = bp_exp, n = 0)
)
level_info <- list(
list(name = "Tax Revenues",  ts = tax_lev),
list(name = "BIR",           ts = bir_lev),
list(name = "BOC",           ts = boc_lev),
list(name = "Expenditures",  ts = exp_lev)
)
# ══════════════════════════════════════════════════════════
# PART 1: GROWTH RATE BREAKS
# ══════════════════════════════════════════════════════════
par(mfrow = c(2, 2), mar = c(4, 4, 3, 1) + 0.1, oma = c(0, 0, 2, 0))
for (info in growth_info) {
n <- info$n
bp_idx <- breakpoints(info$bp, breaks = n)$breakpoints
plot(info$ts, main = paste0(info$name, " – ", n, " Break(s)"),
xlab = "Date", ylab = "YoY Growth (%)", col = "darkgray", lwd = 1, type = "l")
lines(fitted(info$bp, breaks = n), col = "blue", lwd = 2)
abline(v = index(info$ts)[bp_idx], col = "red", lty = 2, lwd = 1.5)
ci <- confint(info$bp, breaks = n)
for (i in 1:n) {
rect(index(info$ts)[ci$confint[i, 1]], par("usr")[3],
index(info$ts)[ci$confint[i, 3]], par("usr")[4],
col = rgb(1, 0, 0, 0.1), border = NA)
}
legend("bottomleft", legend = c("Observed", "Regime mean", "Break"),
col = c("darkgray", "blue", "red"), lty = c(1, 1, 2), bty = "n", cex = 0.8)
}
library(strucchange)
library(zoo)
library(dplyr)
# ── Load & Prep ──────────────────────────────────────────
df <- read.csv("D:/School/ADMU/M AMF/caps_git/Data/cordata.csv", stringsAsFactors = FALSE)
df$Date <- as.Date(df$Date, format = "%m/%d/%Y")
df$date <- NULL
keep_cols <- c("Date", "Tax.Revenues", "BIR", "BOC", "Expenditures")
df_sel <- df[, keep_cols]
df_sel_92 <- df_sel %>% filter(Date >= as.Date("1992-01-01"))
names(df_sel_92) <- c("Date", "Tax", "BIR", "BOC", "Exp")
# ── YoY Growth ───────────────────────────────────────────
df_growth <- df_sel_92 %>%
arrange(Date) %>%
mutate(across(-Date, ~ (. / dplyr::lag(., 12) - 1) * 100, .names = "{.col}_growth")) %>%
filter(if_all(ends_with("_growth"), ~ !is.na(.)))
# ── Zoo Series ───────────────────────────────────────────
tax_ts <- zoo(df_growth$Tax_growth, order.by = df_growth$Date)
bir_ts <- zoo(df_growth$BIR_growth, order.by = df_growth$Date)
boc_ts <- zoo(df_growth$BOC_growth, order.by = df_growth$Date)
exp_ts <- zoo(df_growth$Exp_growth, order.by = df_growth$Date)
tax_lev <- zoo(df_sel_92$Tax, order.by = df_sel_92$Date)
bir_lev <- zoo(df_sel_92$BIR, order.by = df_sel_92$Date)
boc_lev <- zoo(df_sel_92$BOC, order.by = df_sel_92$Date)
exp_lev <- zoo(df_sel_92$Exp, order.by = df_sel_92$Date)
h_value <- 12
# ── Info lists ───────────────────────────────────────────
bp_tax <- breakpoints(tax_ts ~ 1, h = h_value)
bp_bir <- breakpoints(bir_ts ~ 1, h = h_value)
bp_boc <- breakpoints(boc_ts ~ 1, h = h_value)
bp_exp <- breakpoints(exp_ts ~ 1, h = h_value)
growth_info <- list(
list(name = "Tax Revenues",  ts = tax_ts, bp = bp_tax, n = 6),
list(name = "BIR",           ts = bir_ts, bp = bp_bir, n = 1),
list(name = "BOC",           ts = boc_ts, bp = bp_boc, n = 9),
list(name = "Expenditures",  ts = exp_ts, bp = bp_exp, n = 0)
)
level_info <- list(
list(name = "Tax Revenues",  ts = tax_lev),
list(name = "BIR",           ts = bir_lev),
list(name = "BOC",           ts = boc_lev),
list(name = "Expenditures",  ts = exp_lev)
)
# ══════════════════════════════════════════════════════════
# PART 1: GROWTH RATE BREAKS
# ══════════════════════════════════════════════════════════
par(mfrow = c(2, 2), mar = c(4, 4, 3, 1) + 0.1, oma = c(0, 0, 2, 0))
for (info in growth_info) {
n <- info$n
plot(info$ts, main = paste0(info$name, " – ", n, " Break(s)"),
xlab = "Date", ylab = "YoY Growth (%)", col = "darkgray", lwd = 1, type = "l")
lines(fitted(info$bp, breaks = n), col = "blue", lwd = 2)
if (n > 0) {
bp_idx <- breakpoints(info$bp, breaks = n)$breakpoints
abline(v = index(info$ts)[bp_idx], col = "red", lty = 2, lwd = 1.5)
ci <- confint(info$bp, breaks = n)
for (i in 1:n) {
rect(index(info$ts)[ci$confint[i, 1]], par("usr")[3],
index(info$ts)[ci$confint[i, 3]], par("usr")[4],
col = rgb(1, 0, 0, 0.1), border = NA)
}
}
legend("bottomleft", legend = c("Observed", "Regime mean", "Break"),
col = c("darkgray", "blue", "red"), lty = c(1, 1, 2), bty = "n", cex = 0.8)
}
mtext("Bai-Perron — YoY Growth (h = 12)", outer = TRUE, cex = 1.2, line = 0.5)
par(mfrow = c(1, 1))
cat("\n\n", paste(rep("=", 60), collapse = ""), "\n")
cat("  GROWTH RATE BREAKS\n")
cat(paste(rep("=", 60), collapse = ""), "\n")
for (info in growth_info) {
cat("\n===", info$name, "===\n")
if (info$n == 0) {
cat("No breaks detected.\n")
cat("Overall stats:\n")
print(c(mean = mean(coredata(info$ts)), sd = sd(coredata(info$ts)), n = length(info$ts)))
next
}
cat("Break dates:\n")
print(index(info$ts)[breakpoints(info$bp, breaks = info$n)$breakpoints])
cat("Segment stats:\n")
seg <- breakfactor(info$bp, breaks = info$n)
print(tapply(coredata(info$ts), seg, function(x) c(mean = mean(x), sd = sd(x), n = length(x))))
}
# ══════════════════════════════════════════════════════════
# PART 2: VARIANCE BREAKS ON GROWTH RATES
# ══════════════════════════════════════════════════════════
cat("\n\n", paste(rep("=", 60), collapse = ""), "\n")
cat("  VARIANCE BREAKS (GROWTH RATES)\n")
cat(paste(rep("=", 60), collapse = ""), "\n")
for (info in growth_info) {
cat("\n===", info$name, "===\n")
resids <- residuals(lm(coredata(info$ts) ~ 1))
var_ts <- zoo(resids^2, order.by = index(info$ts))
bp_var <- breakpoints(var_ts ~ 1, h = h_value)
opt_bp <- breakpoints(bp_var)$breakpoints
opt_m <- length(opt_bp)
cat("BIC optimal m =", opt_m, "\n")
if (opt_m > 0 && !any(is.na(opt_bp))) {
cat("Break dates:\n")
print(index(info$ts)[opt_bp])
cat("Segment stats:\n")
seg <- breakfactor(bp_var)
print(tapply(coredata(var_ts), seg, function(x) c(mean_var = mean(x), sd = sd(x), n = length(x))))
} else {
cat("No variance breaks detected.\n")
}
}
# ══════════════════════════════════════════════════════════
# PART 3: STRUCTURAL BREAKS IN LEVELS (WITH TREND)
# ══════════════════════════════════════════════════════════
cat("\n\n", paste(rep("=", 60), collapse = ""), "\n")
cat("  STRUCTURAL BREAKS (PRICE LEVELS WITH TREND)\n")
cat(paste(rep("=", 60), collapse = ""), "\n")
for (info in level_info) {
cat("\n===", info$name, "===\n")
t_index <- seq_along(info$ts)
bp_lev <- breakpoints(coredata(info$ts) ~ t_index, h = h_value)
opt_bp <- breakpoints(bp_lev)$breakpoints
opt_m <- length(opt_bp)
cat("BIC optimal m =", opt_m, "\n")
if (opt_m > 0 && !any(is.na(opt_bp))) {
cat("Break dates:\n")
print(index(info$ts)[opt_bp])
cat("Segment stats (intercept + trend per segment):\n")
print(coef(bp_lev))
} else {
cat("No breaks detected.\n")
}
}
library(strucchange)
library(zoo)
library(dplyr)
# ── Load & Prep ──────────────────────────────────────────
df <- read.csv('/Users/pjam/Desktop/School/M AMF/caps/Data/cordata.csv', stringsAsFactors = FALSE)
df$Date <- as.Date(df$Date, format = "%m/%d/%Y")
df$date <- NULL
keep_cols <- c("Date", "Tax.Revenues", "BIR", "BOC", "Expenditures")
df_sel <- df[, keep_cols]
df_sel_92 <- df_sel %>% filter(Date >= as.Date("1992-01-01"))
names(df_sel_92) <- c("Date", "Tax", "BIR", "BOC", "Exp")
# ── YoY Growth ───────────────────────────────────────────
df_growth <- df_sel_92 %>%
arrange(Date) %>%
mutate(across(-Date, ~ (. / dplyr::lag(., 12) - 1) * 100, .names = "{.col}_growth")) %>%
filter(if_all(ends_with("_growth"), ~ !is.na(.)))
# ── Zoo Series ───────────────────────────────────────────
tax_ts <- zoo(df_growth$Tax_growth, order.by = df_growth$Date)
bir_ts <- zoo(df_growth$BIR_growth, order.by = df_growth$Date)
boc_ts <- zoo(df_growth$BOC_growth, order.by = df_growth$Date)
exp_ts <- zoo(df_growth$Exp_growth, order.by = df_growth$Date)
tax_lev <- zoo(df_sel_92$Tax, order.by = df_sel_92$Date)
bir_lev <- zoo(df_sel_92$BIR, order.by = df_sel_92$Date)
boc_lev <- zoo(df_sel_92$BOC, order.by = df_sel_92$Date)
exp_lev <- zoo(df_sel_92$Exp, order.by = df_sel_92$Date)
# ══════════════════════════════════════════════════════════
# MAIN LOOP OVER h VALUES
# ══════════════════════════════════════════════════════════
for (h_value in c(12, 24, 36)) {
cat("\n\n")
cat(paste(rep("#", 70), collapse = ""), "\n")
cat(paste0("  h = ", h_value, "\n"))
cat(paste(rep("#", 70), collapse = ""), "\n")
# ── Breakpoint objects ───────────────────────────────────
bp_tax <- breakpoints(tax_ts ~ 1, h = h_value)
bp_bir <- breakpoints(bir_ts ~ 1, h = h_value)
bp_boc <- breakpoints(boc_ts ~ 1, h = h_value)
bp_exp <- breakpoints(exp_ts ~ 1, h = h_value)
# ── Determine BIC-optimal number of breaks ───────────────
n_tax <- length(breakpoints(bp_tax)$breakpoints)
n_bir <- length(breakpoints(bp_bir)$breakpoints)
n_boc <- length(breakpoints(bp_boc)$breakpoints)
n_exp <- length(breakpoints(bp_exp)$breakpoints)
# Guard against NA (no break found)
n_tax <- ifelse(any(is.na(breakpoints(bp_tax)$breakpoints)), 0, n_tax)
n_bir <- ifelse(any(is.na(breakpoints(bp_bir)$breakpoints)), 0, n_bir)
n_boc <- ifelse(any(is.na(breakpoints(bp_boc)$breakpoints)), 0, n_boc)
n_exp <- ifelse(any(is.na(breakpoints(bp_exp)$breakpoints)), 0, n_exp)
growth_info <- list(
list(name = "Tax Revenues", ts = tax_ts, bp = bp_tax, n = n_tax),
list(name = "BIR",          ts = bir_ts, bp = bp_bir, n = n_bir),
list(name = "BOC",          ts = boc_ts, bp = bp_boc, n = n_boc),
list(name = "Expenditures", ts = exp_ts, bp = bp_exp, n = n_exp)
)
level_info <- list(
list(name = "Tax Revenues", ts = tax_lev),
list(name = "BIR",          ts = bir_lev),
list(name = "BOC",          ts = boc_lev),
list(name = "Expenditures", ts = exp_lev)
)
# ════════════════════════════════════════════════════════
# YoY GROWTH RATE BREAKS — Plot
# ════════════════════════════════════════════════════════
par(mfrow = c(2, 2), mar = c(4, 4, 3, 1) + 0.1, oma = c(0, 0, 2, 0))
for (info in growth_info) {
n <- info$n
plot(info$ts, main = paste0(info$name, " – ", n, " Break(s)"),
xlab = "Date", ylab = "YoY Growth (%)", col = "darkgray", lwd = 1, type = "l")
lines(fitted(info$bp, breaks = n), col = "blue", lwd = 2)
if (n > 0) {
bp_idx <- breakpoints(info$bp, breaks = n)$breakpoints
abline(v = index(info$ts)[bp_idx], col = "red", lty = 2, lwd = 1.5)
ci <- confint(info$bp, breaks = n)
for (i in 1:n) {
rect(index(info$ts)[ci$confint[i, 1]], par("usr")[3],
index(info$ts)[ci$confint[i, 3]], par("usr")[4],
col = rgb(1, 0, 0, 0.1), border = NA)
}
}
legend("bottomleft", legend = c("Observed", "Regime mean", "Break"),
col = c("darkgray", "blue", "red"), lty = c(1, 1, 2), bty = "n", cex = 0.8)
}
mtext(paste0("Bai-Perron — YoY Growth (h = ", h_value, ")"),
outer = TRUE, cex = 1.2, line = 0.5)
par(mfrow = c(1, 1))
# ════════════════════════════════════════════════════════
# YoY GROWTH RATE BREAKS — Console
# ════════════════════════════════════════════════════════
cat("\n\n", paste(rep("=", 60), collapse = ""), "\n")
cat(paste0("  GROWTH RATE BREAKS  (h = ", h_value, ")\n"))
cat(paste(rep("=", 60), collapse = ""), "\n")
for (info in growth_info) {
cat("\n===", info$name, "===\n")
if (info$n == 0) {
cat("No breaks detected.\n")
cat("Overall stats:\n")
print(c(mean = mean(coredata(info$ts)), sd = sd(coredata(info$ts)), n = length(info$ts)))
next
}
cat("Break dates:\n")
print(index(info$ts)[breakpoints(info$bp, breaks = info$n)$breakpoints])
cat("Segment stats:\n")
seg <- breakfactor(info$bp, breaks = info$n)
print(tapply(coredata(info$ts), seg, function(x) c(mean = mean(x), sd = sd(x), n = length(x))))
}
# ════════════════════════════════════════════════════════
# STRUCTURAL BREAKS IN LEVELS (WITH TREND) — Console
# ════════════════════════════════════════════════════════
cat("\n\n", paste(rep("=", 60), collapse = ""), "\n")
cat(paste0("  STRUCTURAL BREAKS (LEVELS WITH TREND)  (h = ", h_value, ")\n"))
cat(paste(rep("=", 60), collapse = ""), "\n")
for (info in level_info) {
cat("\n===", info$name, "===\n")
t_index <- seq_along(info$ts)
bp_lev  <- breakpoints(coredata(info$ts) ~ t_index, h = h_value)
opt_bp  <- breakpoints(bp_lev)$breakpoints
opt_m   <- ifelse(any(is.na(opt_bp)), 0, length(opt_bp))
cat("BIC optimal m =", opt_m, "\n")
if (opt_m > 0) {
cat("Break dates:\n")
print(index(info$ts)[opt_bp])
cat("Segment stats (intercept + trend per segment):\n")
print(coef(bp_lev))
} else {
cat("No breaks detected.\n")
}
}
} # ── end h_value loop ────────────────────────────────────
library(strucchange)
library(zoo)
library(dplyr)
# ── Load & Prep ──────────────────────────────────────────
df <- read.csv('/Users/pjam/Desktop/School/M AMF/caps/Data/cordata.csv', stringsAsFactors = FALSE)
df$Date <- as.Date(df$Date, format = "%m/%d/%Y")
df$date <- NULL
keep_cols <- c("Date", "Tax.Revenues", "BIR", "BOC", "Expenditures")
df_sel <- df[, keep_cols]
df_sel_92 <- df_sel %>% filter(Date >= as.Date("1992-01-01"))
names(df_sel_92) <- c("Date", "Tax", "BIR", "BOC", "Exp")
# ── YoY Growth ───────────────────────────────────────────
df_growth <- df_sel_92 %>%
arrange(Date) %>%
mutate(across(-Date, ~ (. / dplyr::lag(., 12) - 1) * 100, .names = "{.col}_growth")) %>%
filter(if_all(ends_with("_growth"), ~ !is.na(.)))
# ── Zoo Series ───────────────────────────────────────────
tax_ts <- zoo(df_growth$Tax_growth, order.by = df_growth$Date)
bir_ts <- zoo(df_growth$BIR_growth, order.by = df_growth$Date)
boc_ts <- zoo(df_growth$BOC_growth, order.by = df_growth$Date)
exp_ts <- zoo(df_growth$Exp_growth, order.by = df_growth$Date)
tax_lev <- zoo(df_sel_92$Tax, order.by = df_sel_92$Date)
bir_lev <- zoo(df_sel_92$BIR, order.by = df_sel_92$Date)
boc_lev <- zoo(df_sel_92$BOC, order.by = df_sel_92$Date)
exp_lev <- zoo(df_sel_92$Exp, order.by = df_sel_92$Date)
# ══════════════════════════════════════════════════════════
# MAIN LOOP OVER h VALUES
# ══════════════════════════════════════════════════════════
for (h_value in c(12, 24, 36)) {
cat("\n\n")
cat(paste(rep("#", 70), collapse = ""), "\n")
cat(paste0("  h = ", h_value, "\n"))
cat(paste(rep("#", 70), collapse = ""), "\n")
# ── Breakpoint objects ───────────────────────────────────
bp_tax <- breakpoints(tax_ts ~ 1, h = h_value)
bp_bir <- breakpoints(bir_ts ~ 1, h = h_value)
bp_boc <- breakpoints(boc_ts ~ 1, h = h_value)
bp_exp <- breakpoints(exp_ts ~ 1, h = h_value)
# ── Determine BIC-optimal number of breaks ───────────────
n_tax <- length(breakpoints(bp_tax)$breakpoints)
n_bir <- length(breakpoints(bp_bir)$breakpoints)
n_boc <- length(breakpoints(bp_boc)$breakpoints)
n_exp <- length(breakpoints(bp_exp)$breakpoints)
# Guard against NA (no break found)
n_tax <- ifelse(any(is.na(breakpoints(bp_tax)$breakpoints)), 0, n_tax)
n_bir <- ifelse(any(is.na(breakpoints(bp_bir)$breakpoints)), 0, n_bir)
n_boc <- ifelse(any(is.na(breakpoints(bp_boc)$breakpoints)), 0, n_boc)
n_exp <- ifelse(any(is.na(breakpoints(bp_exp)$breakpoints)), 0, n_exp)
growth_info <- list(
list(name = "Tax Revenues", ts = tax_ts, bp = bp_tax, n = n_tax),
list(name = "BIR",          ts = bir_ts, bp = bp_bir, n = n_bir),
list(name = "BOC",          ts = boc_ts, bp = bp_boc, n = n_boc),
list(name = "Expenditures", ts = exp_ts, bp = bp_exp, n = n_exp)
)
level_info <- list(
list(name = "Tax Revenues", ts = tax_lev),
list(name = "BIR",          ts = bir_lev),
list(name = "BOC",          ts = boc_lev),
list(name = "Expenditures", ts = exp_lev)
)
# ════════════════════════════════════════════════════════
# YoY GROWTH RATE BREAKS — Plot
# ════════════════════════════════════════════════════════
par(mfrow = c(2, 2), mar = c(4, 4, 3, 1) + 0.1, oma = c(0, 0, 2, 0))
for (info in growth_info) {
n <- info$n
plot(info$ts, main = paste0(info$name, " – ", n, " Break(s)"),
xlab = "Date", ylab = "YoY Growth (%)", col = "darkgray", lwd = 1, type = "l")
lines(fitted(info$bp, breaks = n), col = "blue", lwd = 2)
if (n > 0) {
bp_idx <- breakpoints(info$bp, breaks = n)$breakpoints
abline(v = index(info$ts)[bp_idx], col = "red", lty = 2, lwd = 1.5)
ci <- confint(info$bp, breaks = n)
for (i in 1:n) {
rect(index(info$ts)[ci$confint[i, 1]], par("usr")[3],
index(info$ts)[ci$confint[i, 3]], par("usr")[4],
col = rgb(1, 0, 0, 0.1), border = NA)
}
}
legend("bottomleft", legend = c("Observed", "Regime mean", "Break"),
col = c("darkgray", "blue", "red"), lty = c(1, 1, 2), bty = "n", cex = 0.8)
}
mtext(paste0("Bai-Perron — YoY Growth (h = ", h_value, ")"),
outer = TRUE, cex = 1.2, line = 0.5)
par(mfrow = c(1, 1))
# ════════════════════════════════════════════════════════
# YoY GROWTH RATE BREAKS — Console
# ════════════════════════════════════════════════════════
cat("\n\n", paste(rep("=", 60), collapse = ""), "\n")
cat(paste0("  GROWTH RATE BREAKS  (h = ", h_value, ")\n"))
cat(paste(rep("=", 60), collapse = ""), "\n")
for (info in growth_info) {
cat("\n===", info$name, "===\n")
if (info$n == 0) {
cat("No breaks detected.\n")
cat("Overall stats:\n")
print(c(mean = mean(coredata(info$ts)), sd = sd(coredata(info$ts)), n = length(info$ts)))
next
}
cat("Break dates:\n")
print(index(info$ts)[breakpoints(info$bp, breaks = info$n)$breakpoints])
cat("Segment stats:\n")
seg <- breakfactor(info$bp, breaks = info$n)
print(tapply(coredata(info$ts), seg, function(x) c(mean = mean(x), sd = sd(x), n = length(x))))
}
# ════════════════════════════════════════════════════════
# STRUCTURAL BREAKS IN LEVELS (WITH TREND) — Compute & store
# ════════════════════════════════════════════════════════
# Attach bp_lev and opt_m to each level_info entry
level_info_fit <- lapply(level_info, function(info) {
t_index <- seq_along(info$ts)
bp_lev  <- breakpoints(coredata(info$ts) ~ t_index, h = h_value)
opt_bp  <- breakpoints(bp_lev)$breakpoints
opt_m   <- ifelse(any(is.na(opt_bp)), 0, length(opt_bp))
info$bp_lev <- bp_lev
info$opt_bp <- opt_bp
info$opt_m  <- opt_m
info
})
# ── Console output ────────────────────────────────────────
cat("\n\n", paste(rep("=", 60), collapse = ""), "\n")
cat(paste0("  STRUCTURAL BREAKS (LEVELS WITH TREND)  (h = ", h_value, ")\n"))
cat(paste(rep("=", 60), collapse = ""), "\n")
for (info in level_info_fit) {
cat("\n===", info$name, "===\n")
cat("BIC optimal m =", info$opt_m, "\n")
if (info$opt_m > 0) {
cat("Break dates:\n")
print(index(info$ts)[info$opt_bp])
cat("Segment stats (intercept + trend per segment):\n")
print(coef(info$bp_lev))
} else {
cat("No breaks detected.\n")
}
}
# ════════════════════════════════════════════════════════
# LEVEL BREAKS — 4-in-1 Plot (fitted segment trends)
# ════════════════════════════════════════════════════════
par(mfrow = c(2, 2), mar = c(4, 4, 3, 1) + 0.1, oma = c(0, 0, 2, 0))
for (info in level_info_fit) {
m <- info$opt_m
t_index <- seq_along(info$ts)
plot(info$ts, main = paste0(info$name, " – ", m, " Break(s)"),
xlab = "Date", ylab = "Level", col = "darkgray", lwd = 1, type = "l")
# Fitted segment trends
lines(zoo(fitted(info$bp_lev, breaks = m), order.by = index(info$ts)),
col = "blue", lwd = 2)
if (m > 0) {
abline(v = index(info$ts)[info$opt_bp], col = "red", lty = 2, lwd = 1.5)
ci <- confint(info$bp_lev, breaks = m)
for (i in 1:m) {
rect(index(info$ts)[ci$confint[i, 1]], par("usr")[3],
index(info$ts)[ci$confint[i, 3]], par("usr")[4],
col = rgb(1, 0, 0, 0.1), border = NA)
}
}
legend("topleft", legend = c("Observed", "Segment trend", "Break"),
col = c("darkgray", "blue", "red"), lty = c(1, 1, 2), bty = "n", cex = 0.8)
}
mtext(paste0("Bai-Perron — Levels with Trend (h = ", h_value, ")"),
outer = TRUE, cex = 1.2, line = 0.5)
par(mfrow = c(1, 1))
# ════════════════════════════════════════════════════════
# LEVEL BREAKS — Individual segment trend plots
# ════════════════════════════════════════════════════════
seg_colors <- c("blue", "darkorange", "green4", "purple", "brown", "red",
"steelblue", "darkgreen", "pink", "black")
for (info in level_info_fit) {
m <- info$opt_m
t_index <- seq_along(info$ts)
# Break indices: start/end of each segment
if (m > 0) {
bp_idx  <- info$opt_bp
starts  <- c(1, bp_idx + 1)
ends    <- c(bp_idx, length(info$ts))
} else {
starts <- 1
ends   <- length(info$ts)
}
n_seg <- length(starts)
plot(info$ts, col = "darkgray", lwd = 1,
main = paste0(info$name, " — Segment Trends (h = ", h_value, ")"),
ylab = "Level", xlab = "Date")
leg_labels <- "Observed"
leg_cols   <- "darkgray"
leg_lty    <- 1
leg_lwd    <- 1
for (s in seq_len(n_seg)) {
seg_ts  <- window(info$ts,
start = index(info$ts)[starts[s]],
end   = index(info$ts)[ends[s]])
fit_s   <- lm(coredata(seg_ts) ~ seq_along(seg_ts))
col_s   <- seg_colors[(s - 1) %% length(seg_colors) + 1]
lines(zoo(fitted(fit_s), order.by = index(seg_ts)), col = col_s, lwd = 2)
# Label: date range
lbl <- paste0(format(index(info$ts)[starts[s]], "%Y-%m"),
" – ",
format(index(info$ts)[ends[s]],   "%Y-%m"))
leg_labels <- c(leg_labels, lbl)
leg_cols   <- c(leg_cols, col_s)
leg_lty    <- c(leg_lty, 1)
leg_lwd    <- c(leg_lwd, 2)
}
# Break lines
if (m > 0) {
for (b in seq_len(m)) {
abline(v = index(info$ts)[info$opt_bp[b]], col = "red", lty = 2, lwd = 1.5)
}
leg_labels <- c(leg_labels, "Break")
leg_cols   <- c(leg_cols, "red")
leg_lty    <- c(leg_lty, 2)
leg_lwd    <- c(leg_lwd, 1.5)
}
legend("topleft", legend = leg_labels, col = leg_cols,
lty = leg_lty, lwd = leg_lwd, bty = "n", cex = 0.75)
}
} # ── end h_value loop ────────────────────────────────────

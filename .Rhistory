bir_g_bd <- get_bp_dates(bp_bir_g, bir_ts)
boc_g_bd <- get_bp_dates(bp_boc_g, boc_ts)
exp_g_bd <- get_bp_dates(bp_exp_g, exp_ts)
tax_l_bd <- get_bp_dates(bp_tax_l, tax_lev)
bir_l_bd <- get_bp_dates(bp_bir_l, bir_lev)
boc_l_bd <- get_bp_dates(bp_boc_l, boc_lev)
exp_l_bd <- get_bp_dates(bp_exp_l, exp_lev)
# ════════════════════════════════════════════════════════
# PLOT 1: 4-in-1 YoY Growth Bai-Perron overview
# ════════════════════════════════════════════════════════
seg_colors <- c("blue", "darkorange", "green4", "purple", "brown",
"red", "steelblue", "darkgreen", "pink", "black")
par(mfrow = c(2, 2), mar = c(4, 4, 3, 1) + 0.1, oma = c(0, 0, 2, 0))
for (info in growth_info) {
n  <- info$n
bd <- get_bp_dates(info$bp, info$ts)
plot(info$ts,
main = paste0(info$name, " - ", n, " Break(s)"),
xlab = "Date", ylab = "YoY Growth (%)",
col = "darkgray", lwd = 1, type = "l")
abline(h = 0, col = "black", lty = 3, lwd = 1)
# segment means using calendar-date windows
all_d  <- index(info$ts)
if (n > 0) {
starts <- c(all_d[1], bd)
ends   <- c(bd - 1, all_d[length(all_d)])
} else {
starts <- all_d[1]
ends   <- all_d[length(all_d)]
}
for (s in seq_along(starts)) {
seg_ts <- window(info$ts, start = starts[s], end = ends[s])
m_s    <- mean(coredata(seg_ts))
col_s  <- seg_colors[(s - 1) %% length(seg_colors) + 1]
lines(zoo(rep(m_s, length(seg_ts)), order.by = index(seg_ts)),
col = col_s, lwd = 2)
}
if (n > 0) {
abline(v = bd, col = "red", lty = 2, lwd = 1.5)
ci <- confint(info$bp, breaks = n)
for (i in seq_len(n))
rect(index(info$ts)[ci$confint[i, 1]], par("usr")[3],
index(info$ts)[ci$confint[i, 3]], par("usr")[4],
col = rgb(1, 0, 0, 0.1), border = NA)
}
legend("bottomleft", legend = c("Observed", "Segment mean", "Break"),
col = c("darkgray", seg_colors[1], "red"), lty = c(1, 1, 2),
bty = "n", cex = 0.8)
}
mtext(paste0("Bai-Perron - YoY Growth (h = ", h_value, ")"),
outer = TRUE, cex = 1.2, line = 0.5)
par(mfrow = c(1, 1))
# ════════════════════════════════════════════════════════
# PLOT 2: Individual YoY segment means
# ════════════════════════════════════════════════════════
plot_seg_means(tax_ts, tax_g_bd,
title = paste0("Tax Revenues - YoY Segment Means (h=", h_value, ")"),
ylab  = "YoY Growth (%)")
plot_seg_means(bir_ts, bir_g_bd,
title = paste0("BIR - YoY Segment Means (h=", h_value, ")"),
ylab  = "YoY Growth (%)")
plot_seg_means(boc_ts, boc_g_bd,
title = paste0("BOC - YoY Segment Means (h=", h_value, ")"),
ylab  = "YoY Growth (%)")
plot_seg_means(exp_ts, exp_g_bd,
title = paste0("Expenditures - YoY Segment Means (h=", h_value, ")"),
ylab  = "YoY Growth (%)")
# ════════════════════════════════════════════════════════
# Console: Growth breaks
# ════════════════════════════════════════════════════════
cat("\n\n", paste(rep("=", 60), collapse = ""), "\n")
cat(paste0("  GROWTH RATE BREAKS  (h = ", h_value, ")\n"))
cat(paste(rep("=", 60), collapse = ""), "\n")
for (info in growth_info) {
cat("\n===", info$name, "===\n")
if (info$n == 0) {
cat("No breaks detected.\n")
print(c(mean = mean(coredata(info$ts)),
sd   = sd(coredata(info$ts)),
n    = length(info$ts)))
next
}
cat("Break dates:\n")
print(index(info$ts)[breakpoints(info$bp, breaks = info$n)$breakpoints])
cat("Segment stats:\n")
seg <- breakfactor(info$bp, breaks = info$n)
print(tapply(coredata(info$ts), seg,
function(x) c(mean = mean(x), sd = sd(x), n = length(x))))
}
# ════════════════════════════════════════════════════════
# PLOT 3: 4-in-1 Level Bai-Perron overview
# ════════════════════════════════════════════════════════
par(mfrow = c(2, 2), mar = c(4, 4, 3, 1) + 0.1, oma = c(0, 0, 2, 0))
for (info in list(
list(name = "Tax Revenues", ts = tax_lev, bd = tax_l_bd, bp = bp_tax_l),
list(name = "BIR",          ts = bir_lev, bd = bir_l_bd, bp = bp_bir_l),
list(name = "BOC",          ts = boc_lev, bd = boc_l_bd, bp = bp_boc_l),
list(name = "Expenditures", ts = exp_lev, bd = exp_l_bd, bp = bp_exp_l)
)) {
m <- length(info$bd)
plot(info$ts,
main = paste0(info$name, " - ", m, " Break(s)"),
xlab = "Date", ylab = "Level",
col = "darkgray", lwd = 1, type = "l")
if (m > 0) {
# draw per-segment lm using calendar dates (same logic as helper)
all_d  <- index(info$ts)
starts <- c(all_d[1], info$bd)
ends_v <- c(info$bd - 32, all_d[length(all_d)])
ends_v <- as.Date(sapply(ends_v, function(d) max(all_d[all_d <= d])),
origin = "1970-01-01")
seg_cols <- c("purple","blue","darkorange","brown","red","green4",
"steelblue","darkgreen","pink","black")
for (s in seq_along(starts)) {
seg_ts <- window(info$ts, start = starts[s], end = ends_v[s])
fit_s  <- lm(coredata(seg_ts) ~ seq_along(seg_ts))
col_s  <- seg_cols[(s-1) %% length(seg_cols) + 1]
lines(zoo(fitted(fit_s), order.by = index(seg_ts)), col = col_s, lwd = 2)
}
abline(v = info$bd, col = "red", lty = 2, lwd = 1.5)
bp_obj <- info$bp
ci <- confint(bp_obj, breaks = m)
for (i in seq_len(m))
rect(index(info$ts)[ci$confint[i, 1]], par("usr")[3],
index(info$ts)[ci$confint[i, 3]], par("usr")[4],
col = rgb(1, 0, 0, 0.1), border = NA)
} else {
seg_ts <- info$ts
fit_s  <- lm(coredata(seg_ts) ~ seq_along(seg_ts))
lines(zoo(fitted(fit_s), order.by = index(seg_ts)), col = "blue", lwd = 2)
}
legend("topleft", legend = c("Observed", "Segment trend", "Break"),
col = c("darkgray", "blue", "red"), lty = c(1, 1, 2),
bty = "n", cex = 0.8)
}
mtext(paste0("Bai-Perron - Levels with Trend (h = ", h_value, ")"),
outer = TRUE, cex = 1.2, line = 0.5)
par(mfrow = c(1, 1))
# ════════════════════════════════════════════════════════
# PLOT 4: Individual level segment trends
# ════════════════════════════════════════════════════════
plot_seg_trends(tax_lev, tax_l_bd,
title = paste0("Tax Revenues - Segment Trends (h=", h_value, ")"),
ylab  = "Level")
plot_seg_trends(bir_lev, bir_l_bd,
title = paste0("BIR - Segment Trends (h=", h_value, ")"),
ylab  = "Level")
plot_seg_trends(boc_lev, boc_l_bd,
title = paste0("BOC - Segment Trends (h=", h_value, ")"),
ylab  = "Level")
plot_seg_trends(exp_lev, exp_l_bd,
title = paste0("Expenditures - Segment Trends (h=", h_value, ")"),
ylab  = "Level")
# ════════════════════════════════════════════════════════
# Console: Level breaks
# ════════════════════════════════════════════════════════
cat("\n\n", paste(rep("=", 60), collapse = ""), "\n")
cat(paste0("  STRUCTURAL BREAKS (LEVELS WITH TREND)  (h = ", h_value, ")\n"))
cat(paste(rep("=", 60), collapse = ""), "\n")
for (info in list(
list(name = "Tax Revenues", ts = tax_lev, bp = bp_tax_l, bd = tax_l_bd),
list(name = "BIR",          ts = bir_lev, bp = bp_bir_l, bd = bir_l_bd),
list(name = "BOC",          ts = boc_lev, bp = bp_boc_l, bd = boc_l_bd),
list(name = "Expenditures", ts = exp_lev, bp = bp_exp_l, bd = exp_l_bd)
)) {
cat("\n===", info$name, "===\n")
cat("BIC optimal m =", length(info$bd), "\n")
if (length(info$bd) > 0) {
cat("Break dates:\n"); print(info$bd)
cat("Segment coefficients (intercept + trend):\n")
print(coef(info$bp))
} else {
cat("No breaks detected.\n")
}
}
} # ── end h_value loop ────────────────────────────────────
library(strucchange)
library(zoo)
library(dplyr)
# ── Load & Prep ──────────────────────────────────────────
df <- read.csv('Data/cordata.csv',
stringsAsFactors = FALSE)
df$Date <- as.Date(df$Date, format = "%m/%d/%Y")
df$date <- NULL
df_sel    <- df[, c("Date", "Tax.Revenues", "BIR", "BOC", "Expenditures")]
df_sel_92 <- df_sel %>% filter(Date >= as.Date("1992-01-01"))
names(df_sel_92) <- c("Date", "Tax", "BIR", "BOC", "Exp")
# ── YoY Growth ───────────────────────────────────────────
df_growth <- df_sel_92 %>%
arrange(Date) %>%
mutate(across(-Date, ~ (. / dplyr::lag(., 12) - 1) * 100,
.names = "{.col}_growth")) %>%
filter(if_all(ends_with("_growth"), ~ !is.na(.)))
# ── Zoo Series ───────────────────────────────────────────
tax_ts  <- zoo(df_growth$Tax_growth, order.by = df_growth$Date)
bir_ts  <- zoo(df_growth$BIR_growth, order.by = df_growth$Date)
boc_ts  <- zoo(df_growth$BOC_growth, order.by = df_growth$Date)
exp_ts  <- zoo(df_growth$Exp_growth, order.by = df_growth$Date)
tax_lev <- zoo(df_sel_92$Tax, order.by = df_sel_92$Date)
bir_lev <- zoo(df_sel_92$BIR, order.by = df_sel_92$Date)
boc_lev <- zoo(df_sel_92$BOC, order.by = df_sel_92$Date)
exp_lev <- zoo(df_sel_92$Exp, order.by = df_sel_92$Date)
# ── Helper: BIC-optimal m ────────────────────────────────
get_opt_m <- function(bp) {
opt <- breakpoints(bp)$breakpoints
if (length(opt) == 0 || all(is.na(opt))) 0L else length(opt)
}
# ── Helper: get break dates from breakpoints object ──────
get_bp_dates <- function(bp, ts) {
idx <- breakpoints(bp)$breakpoints
if (length(idx) == 0 || all(is.na(idx))) return(as.Date(character(0)))
index(ts)[idx]
}
# ── Helper: plot segment trends (lm) using calendar dates ─
# bp_dates: vector of Date — each is the FIRST date of a new segment
#           (i.e. the break date itself, same as your manual window() calls)
plot_seg_trends <- function(ts, bp_dates, title, ylab,
legend_pos  = "topleft",
legend_pos2 = "bottomright",
seg_cols = c("purple", "blue", "darkorange",
"brown", "red", "green4",
"steelblue", "darkgreen", "pink", "black")) {
all_dates  <- index(ts)
first_date <- all_dates[1]
last_date  <- all_dates[length(all_dates)]
if (length(bp_dates) == 0) {
seg_starts <- first_date
seg_ends   <- last_date
} else {
# new segment starts ON the break date (matches your manual window calls)
seg_starts <- c(first_date, bp_dates)
seg_ends   <- c(bp_dates - 1, last_date)
}
n_seg <- length(seg_starts)
plot(ts, col = "darkgray", lwd = 1, type = "l",
main = title, ylab = ylab, xlab = "Date")
leg_labels <- "Observed"
leg_cols   <- "darkgray"
leg_lty    <- 1; leg_lwd <- 1
used_cols  <- character(n_seg)
for (s in seq_len(n_seg)) {
seg_ts <- window(ts, start = seg_starts[s], end = seg_ends[s])
col_s  <- seg_cols[(s - 1) %% length(seg_cols) + 1]
used_cols[s] <- col_s
fit_s  <- lm(coredata(seg_ts) ~ seq_along(seg_ts))
lines(zoo(fitted(fit_s), order.by = index(seg_ts)), col = col_s, lwd = 2)
lbl <- paste0(format(seg_starts[s], "%Y-%m"), " to ",
format(seg_ends[s],   "%Y-%m"))
leg_labels <- c(leg_labels, lbl)
leg_cols   <- c(leg_cols, col_s)
leg_lty    <- c(leg_lty, 1); leg_lwd <- c(leg_lwd, 2)
}
if (length(bp_dates) > 0) {
break_cols <- used_cols[-1]  # break color = color of the segment it starts
for (i in seq_along(bp_dates))
abline(v = bp_dates[i], col = break_cols[i], lty = 2, lwd = 1.5)
legend(legend_pos2,
legend = paste0(format(bp_dates, "%Y"), " break"),
col = break_cols, lty = 2, lwd = 1.5,
bty = "n", cex = 0.7, x.intersp = 0.6, y.intersp = 0.85)
}
legend(legend_pos, legend = leg_labels, col = leg_cols,
lty = leg_lty, lwd = leg_lwd,
bty = "n", cex = 0.7, x.intersp = 0.6, y.intersp = 0.85)
}
# ── Helper: plot segment means using calendar dates ───────
plot_seg_means <- function(ts, bp_dates, title, ylab,
legend_pos = "bottomleft",
seg_cols = c("purple", "blue", "darkorange",
"brown", "red", "green4",
"steelblue", "darkgreen", "pink", "black")) {
all_dates  <- index(ts)
first_date <- all_dates[1]
last_date  <- all_dates[length(all_dates)]
if (length(bp_dates) == 0) {
seg_starts <- first_date
seg_ends   <- last_date
} else {
seg_starts <- c(first_date, bp_dates)
seg_ends   <- c(bp_dates - 1, last_date)
}
n_seg <- length(seg_starts)
plot(ts, col = "darkgray", lwd = 1, type = "l",
main = title, ylab = ylab, xlab = "Date")
abline(h = 0, col = "black", lty = 3, lwd = 1)
leg_labels <- "YoY Growth"
leg_cols   <- "darkgray"
leg_lty    <- 1; leg_lwd <- 1
for (s in seq_len(n_seg)) {
seg_ts <- window(ts, start = seg_starts[s], end = seg_ends[s])
col_s  <- seg_cols[(s - 1) %% length(seg_cols) + 1]
m_s    <- mean(coredata(seg_ts))
lines(zoo(rep(m_s, length(seg_ts)), order.by = index(seg_ts)),
col = col_s, lwd = 2)
lbl <- paste0(format(seg_starts[s], "%Y-%m"), " to ",
format(seg_ends[s],   "%Y-%m"),
" (", round(m_s, 1), "%)")
leg_labels <- c(leg_labels, lbl)
leg_cols   <- c(leg_cols, col_s)
leg_lty    <- c(leg_lty, 1); leg_lwd <- c(leg_lwd, 2)
}
if (length(bp_dates) > 0) {
break_cols <- seg_cols[seq_len(length(bp_dates)) %% length(seg_cols) + 1]
for (i in seq_along(bp_dates))
abline(v = bp_dates[i], col = break_cols[i], lty = 2, lwd = 1.2)
}
legend(legend_pos, legend = leg_labels, col = leg_cols,
lty = leg_lty, lwd = leg_lwd,
bty = "n", cex = 0.65, x.intersp = 0.5, y.intersp = 0.8)
}
# ══════════════════════════════════════════════════════════
# MAIN LOOP OVER h VALUES
# ══════════════════════════════════════════════════════════
for (h_value in c(12, 24, 36)) {
cat("\n\n")
cat(paste(rep("#", 70), collapse = ""), "\n")
cat(paste0("  h = ", h_value, "\n"))
cat(paste(rep("#", 70), collapse = ""), "\n")
# ── Growth breakpoints ───────────────────────────────────
bp_tax_g <- breakpoints(tax_ts ~ 1, h = h_value)
bp_bir_g <- breakpoints(bir_ts ~ 1, h = h_value)
bp_boc_g <- breakpoints(boc_ts ~ 1, h = h_value)
bp_exp_g <- breakpoints(exp_ts ~ 1, h = h_value)
growth_info <- list(
list(name = "Tax Revenues", ts = tax_ts, bp = bp_tax_g, n = get_opt_m(bp_tax_g)),
list(name = "BIR",          ts = bir_ts, bp = bp_bir_g, n = get_opt_m(bp_bir_g)),
list(name = "BOC",          ts = boc_ts, bp = bp_boc_g, n = get_opt_m(bp_boc_g)),
list(name = "Expenditures", ts = exp_ts, bp = bp_exp_g, n = get_opt_m(bp_exp_g))
)
# ── Level breakpoints ────────────────────────────────────
bp_tax_l <- breakpoints(coredata(tax_lev) ~ seq_along(tax_lev), h = h_value)
bp_bir_l <- breakpoints(coredata(bir_lev) ~ seq_along(bir_lev), h = h_value)
bp_boc_l <- breakpoints(coredata(boc_lev) ~ seq_along(boc_lev), h = h_value)
bp_exp_l <- breakpoints(coredata(exp_lev) ~ seq_along(exp_lev), h = h_value)
# ── Extract break dates (calendar) ──────────────────────
tax_g_bd <- get_bp_dates(bp_tax_g, tax_ts)
bir_g_bd <- get_bp_dates(bp_bir_g, bir_ts)
boc_g_bd <- get_bp_dates(bp_boc_g, boc_ts)
exp_g_bd <- get_bp_dates(bp_exp_g, exp_ts)
tax_l_bd <- get_bp_dates(bp_tax_l, tax_lev)
bir_l_bd <- get_bp_dates(bp_bir_l, bir_lev)
boc_l_bd <- get_bp_dates(bp_boc_l, boc_lev)
exp_l_bd <- get_bp_dates(bp_exp_l, exp_lev)
# ════════════════════════════════════════════════════════
# PLOT 1: 4-in-1 YoY Growth Bai-Perron overview
# ════════════════════════════════════════════════════════
seg_colors <- c("blue", "darkorange", "green4", "purple", "brown",
"red", "steelblue", "darkgreen", "pink", "black")
png(paste0("plot_h", h_value, "_01_yoy_overview.png"), width = 1200, height = 900, res = 120)
par(mfrow = c(2, 2), mar = c(4, 4, 3, 1) + 0.1, oma = c(0, 0, 2, 0))
for (info in growth_info) {
n  <- info$n
bd <- get_bp_dates(info$bp, info$ts)
plot(info$ts,
main = paste0(info$name, " - ", n, " Break(s)"),
xlab = "Date", ylab = "YoY Growth (%)",
col = "darkgray", lwd = 1, type = "l")
abline(h = 0, col = "black", lty = 3, lwd = 1)
all_d  <- index(info$ts)
if (n > 0) {
starts <- c(all_d[1], bd)
ends   <- c(bd - 1, all_d[length(all_d)])
} else {
starts <- all_d[1]
ends   <- all_d[length(all_d)]
}
for (s in seq_along(starts)) {
seg_ts <- window(info$ts, start = starts[s], end = ends[s])
m_s    <- mean(coredata(seg_ts))
col_s  <- seg_colors[(s - 1) %% length(seg_colors) + 1]
lines(zoo(rep(m_s, length(seg_ts)), order.by = index(seg_ts)),
col = col_s, lwd = 2)
}
if (n > 0) {
abline(v = bd, col = "red", lty = 2, lwd = 1.5)
ci <- confint(info$bp, breaks = n)
for (i in seq_len(n))
rect(index(info$ts)[ci$confint[i, 1]], par("usr")[3],
index(info$ts)[ci$confint[i, 3]], par("usr")[4],
col = rgb(1, 0, 0, 0.1), border = NA)
}
legend("bottomleft", legend = c("Observed", "Segment mean", "Break"),
col = c("darkgray", seg_colors[1], "red"), lty = c(1, 1, 2),
bty = "n", cex = 0.8)
}
mtext(paste0("Bai-Perron - YoY Growth (h = ", h_value, ")"),
outer = TRUE, cex = 1.2, line = 0.5)
par(mfrow = c(1, 1))
dev.off()
# ════════════════════════════════════════════════════════
# PLOT 2: Individual YoY segment means
# ════════════════════════════════════════════════════════
for (nm in c("Tax Revenues", "BIR", "BOC", "Expenditures")) {
ts_g <- list("Tax Revenues" = tax_ts, "BIR" = bir_ts,
"BOC" = boc_ts, "Expenditures" = exp_ts)[[nm]]
bd_g <- list("Tax Revenues" = tax_g_bd, "BIR" = bir_g_bd,
"BOC" = boc_g_bd, "Expenditures" = exp_g_bd)[[nm]]
fname <- paste0("plot_h", h_value, "_02_yoy_means_",
gsub(" ", "_", nm), ".png")
png(fname, width = 1000, height = 700, res = 120)
plot_seg_means(ts_g, bd_g,
title = paste0(nm, " - YoY Segment Means (h=", h_value, ")"),
ylab  = "YoY Growth (%)")
dev.off()
}
# ════════════════════════════════════════════════════════
# Console: Growth breaks
# ════════════════════════════════════════════════════════
cat("\n\n", paste(rep("=", 60), collapse = ""), "\n")
cat(paste0("  GROWTH RATE BREAKS  (h = ", h_value, ")\n"))
cat(paste(rep("=", 60), collapse = ""), "\n")
for (info in growth_info) {
cat("\n===", info$name, "===\n")
if (info$n == 0) {
cat("No breaks detected.\n")
print(c(mean = mean(coredata(info$ts)),
sd   = sd(coredata(info$ts)),
n    = length(info$ts)))
next
}
cat("Break dates:\n")
print(index(info$ts)[breakpoints(info$bp, breaks = info$n)$breakpoints])
cat("Segment stats:\n")
seg <- breakfactor(info$bp, breaks = info$n)
print(tapply(coredata(info$ts), seg,
function(x) c(mean = mean(x), sd = sd(x), n = length(x))))
}
# ════════════════════════════════════════════════════════
# PLOT 3: 4-in-1 Level Bai-Perron overview
# ════════════════════════════════════════════════════════
png(paste0("plot_h", h_value, "_03_levels_overview.png"), width = 1200, height = 900, res = 120)
par(mfrow = c(2, 2), mar = c(4, 4, 3, 1) + 0.1, oma = c(0, 0, 2, 0))
for (info in list(
list(name = "Tax Revenues", ts = tax_lev, bd = tax_l_bd, bp = bp_tax_l),
list(name = "BIR",          ts = bir_lev, bd = bir_l_bd, bp = bp_bir_l),
list(name = "BOC",          ts = boc_lev, bd = boc_l_bd, bp = bp_boc_l),
list(name = "Expenditures", ts = exp_lev, bd = exp_l_bd, bp = bp_exp_l)
)) {
m <- length(info$bd)
plot(info$ts,
main = paste0(info$name, " - ", m, " Break(s)"),
xlab = "Date", ylab = "Level",
col = "darkgray", lwd = 1, type = "l")
all_d  <- index(info$ts)
if (m > 0) {
starts <- c(all_d[1], info$bd)
ends_v <- c(info$bd - 1, all_d[length(all_d)])
seg_cols <- c("purple","blue","darkorange","brown","red","green4",
"steelblue","darkgreen","pink","black")
for (s in seq_along(starts)) {
seg_ts <- window(info$ts, start = starts[s], end = ends_v[s])
fit_s  <- lm(coredata(seg_ts) ~ seq_along(seg_ts))
col_s  <- seg_cols[(s-1) %% length(seg_cols) + 1]
lines(zoo(fitted(fit_s), order.by = index(seg_ts)), col = col_s, lwd = 2)
}
abline(v = info$bd, col = "red", lty = 2, lwd = 1.5)
ci <- confint(info$bp, breaks = m)
for (i in seq_len(m))
rect(index(info$ts)[ci$confint[i, 1]], par("usr")[3],
index(info$ts)[ci$confint[i, 3]], par("usr")[4],
col = rgb(1, 0, 0, 0.1), border = NA)
} else {
fit_s <- lm(coredata(info$ts) ~ seq_along(info$ts))
lines(zoo(fitted(fit_s), order.by = all_d), col = "blue", lwd = 2)
}
legend("topleft", legend = c("Observed", "Segment trend", "Break"),
col = c("darkgray", "blue", "red"), lty = c(1, 1, 2),
bty = "n", cex = 0.8)
}
mtext(paste0("Bai-Perron - Levels with Trend (h = ", h_value, ")"),
outer = TRUE, cex = 1.2, line = 0.5)
par(mfrow = c(1, 1))
dev.off()
# ════════════════════════════════════════════════════════
# PLOT 4: Individual level segment trends
# ════════════════════════════════════════════════════════
for (nm in c("Tax Revenues", "BIR", "BOC", "Expenditures")) {
ts_l <- list("Tax Revenues" = tax_lev, "BIR" = bir_lev,
"BOC" = boc_lev, "Expenditures" = exp_lev)[[nm]]
bd_l <- list("Tax Revenues" = tax_l_bd, "BIR" = bir_l_bd,
"BOC" = boc_l_bd, "Expenditures" = exp_l_bd)[[nm]]
fname <- paste0("plot_h", h_value, "_04_level_trends_",
gsub(" ", "_", nm), ".png")
png(fname, width = 1000, height = 700, res = 120)
plot_seg_trends(ts_l, bd_l,
title = paste0(nm, " - Segment Trends (h=", h_value, ")"),
ylab  = "Level")
dev.off()
}
# ════════════════════════════════════════════════════════
# Console: Level breaks
# ════════════════════════════════════════════════════════
cat("\n\n", paste(rep("=", 60), collapse = ""), "\n")
cat(paste0("  STRUCTURAL BREAKS (LEVELS WITH TREND)  (h = ", h_value, ")\n"))
cat(paste(rep("=", 60), collapse = ""), "\n")
for (info in list(
list(name = "Tax Revenues", ts = tax_lev, bp = bp_tax_l, bd = tax_l_bd),
list(name = "BIR",          ts = bir_lev, bp = bp_bir_l, bd = bir_l_bd),
list(name = "BOC",          ts = boc_lev, bp = bp_boc_l, bd = boc_l_bd),
list(name = "Expenditures", ts = exp_lev, bp = bp_exp_l, bd = exp_l_bd)
)) {
cat("\n===", info$name, "===\n")
cat("BIC optimal m =", length(info$bd), "\n")
if (length(info$bd) > 0) {
cat("Break dates:\n"); print(info$bd)
cat("Segment coefficients (intercept + trend):\n")
print(coef(info$bp))
} else {
cat("No breaks detected.\n")
}
}
} # ── end h_value loop ────────────────────────────────────
